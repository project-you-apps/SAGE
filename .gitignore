# PyCharm
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/arc-agi-2/
model-zoo/
sage/quantization/diagnostic_report.json

# McNugget local logs (sync logs stay local)
sage/logs/mcnugget/

# Machine-specific daemon runtime state (one daemon per machine)
sage/raising/state/daemon_state_*.json

# Live daemon state files — written continuously by running daemons.
# These cause merge conflicts across machines. Raising sessions should
# snapshot these to sage/instances/<name>/snapshots/ for git persistence.
sage/instances/*/daemon_state.json
sage/instances/*/experience_buffer.json
sage/instances/*/peer_trust.json
sage/instances/*/identity.json
sage/instances/*/chat_history.jsonl
sage/instances/*/llm_pool_state.json
sage/instances/*/memory.db-shm
sage/instances/*/memory.db-wal
# But keep the seed template tracked
!sage/instances/_seed/identity.json
sage/raising/state/daemon_state.json
sage/raising/state/identity.json
sage/raising/state/experience_buffer*.json
sage/raising/state/peer_trust*.json
sage/raising/state/latent_exploration_state.json

# Machine-specific logs
logs/sage-daemon/*.log

# Hardbound local chain state (generated by running daemon)
.hardbound/

